# Dependencies (reinstalled during build)
node_modules/
vendor/

# Frontend build (generated in node-builder stage)
public/build/
public/hot/

# Environment secrets — never bake into the image
.env
.env.*
!.env.example

# Runtime / local state
database/database.sqlite
storage/pail/
storage/*.key

# Git and IDE
.git/
.gitignore
.idea/
.vscode/
.fleet/
.nova/
.zed/

# Logs and cache
*.log
.phpunit.result.cache
/.phpunit.cache

# OS
.DS_Store
Thumbs.db
